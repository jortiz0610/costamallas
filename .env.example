# ============================================================
# COSTAMALLAS ERP — Variables de entorno
# Copiar a .env.local y completar con valores reales
# ============================================================

# Base de datos PostgreSQL (Supabase u otro proveedor)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/costamallas_erp?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/costamallas_erp?schema=public"

# JWT — generar con: openssl rand -base64 64
JWT_SECRET="cambiar_por_secreto_seguro_minimo_64_caracteres_aleatorios"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Cifrado de datos sensibles (AES-256-GCM) — generar con: openssl rand -hex 32
ENCRYPTION_KEY="cambiar_por_clave_hex_de_64_caracteres"

# WooCommerce (se guardan cifrados en la base de datos, estos son fallback)
WC_STORE_URL="https://costamallas.com"
WC_CONSUMER_KEY=""
WC_CONSUMER_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Costamallas ERP"
NODE_ENV="development"

# Rate limiting
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="60000"
