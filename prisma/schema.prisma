// ============================================================
// COSTAMALLAS ERP — Prisma Schema
// Base de datos: PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// USUARIOS Y AUTENTICACIÓN
// ─────────────────────────────────────────────

model Usuario {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  password     String   // bcrypt hash — nunca texto plano
  rol          Rol      @default(USUARIO)
  activo       Boolean  @default(true)
  ultimoAcceso DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  logs          Log[]
  clientesAsignados Cliente[]
  cotizaciones  Cotizacion[]
  pedidos       Pedido[]
  instalaciones Instalacion[]
  nexusMensajes NexusMensaje[]
  tareas        Tarea[]

  @@map("usuarios")
  @@index([email])
}

enum Rol {
  SUPERADMIN
  ADMIN
  USUARIO
  VENDEDOR
  PRODUCCION
  BODEGA
  SOLO_LECTURA
}

// ─────────────────────────────────────────────
// CRM
// ─────────────────────────────────────────────

model Cliente {
  id           String   @id @default(cuid())
  nombre       String
  empresa      String?
  cargo        String?
  email        String?
  telefono     String?
  whatsapp     String?
  ciudad       String?
  departamento String?
  direccion    String?
  nit          String?
  paginaWeb    String?
  tipo         String   @default("persona")
  estado       String   @default("PROSPECTO")
  notas        String?  @db.Text
  vendedorId   String?
  vendedor     Usuario? @relation(fields: [vendedorId], references: [id], onDelete: SetNull)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cotizaciones Cotizacion[]
  pedidos      Pedido[]
  tareas       Tarea[]
  facturas     Factura[]

  @@map("clientes")
  @@index([vendedorId])
  @@index([activo])
  @@index([estado])
}

// ─────────────────────────────────────────────
// FACTURACIÓN (base + electrónica vía tercero/DIAN)
// ─────────────────────────────────────────────

model Factura {
  id           String   @id @default(cuid())
  numero       String   @unique
  prefijo      String?
  consecutivo  Int?

  clienteId    String
  cliente      Cliente  @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  pedidoId     String?
  cotizacionId String?

  estado       String   @default("BORRADOR")
  estadoDian   String   @default("NO_APLICA")
  cufe         String?
  proveedorRef String?
  qrUrl        String?
  xmlUrl       String?
  pdfUrl       String?
  mensajeDian  String?  @db.Text

  subtotal     Decimal  @default(0) @db.Decimal(14, 2)
  descuento    Decimal  @default(0) @db.Decimal(14, 2)
  iva          Decimal  @default(0) @db.Decimal(14, 2)
  total        Decimal  @default(0) @db.Decimal(14, 2)

  formaPago      String?
  metodoPago     String?
  saldoPendiente Decimal @default(0) @db.Decimal(14, 2)
  fechaEmision   DateTime?
  fechaVence     DateTime?

  notas        String?  @db.Text
  items        ItemFactura[]
  pagos        PagoFactura[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("facturas")
  @@index([clienteId])
  @@index([estado])
  @@index([estadoDian])
  @@index([pedidoId])
}

model ItemFactura {
  id             String  @id @default(cuid())
  facturaId      String
  factura        Factura @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  productoId     String?
  descripcion    String
  cantidad       Decimal @db.Decimal(10, 2)
  precioUnitario Decimal @db.Decimal(14, 2)
  descuento      Decimal @default(0) @db.Decimal(5, 2)
  ivaPct         Decimal @default(19) @db.Decimal(5, 2)
  subtotal       Decimal @db.Decimal(14, 2)
  unidad         String?
  orden          Int     @default(0)

  @@map("items_factura")
  @@index([facturaId])
}

model PagoFactura {
  id         String   @id @default(cuid())
  facturaId  String
  factura    Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  monto      Decimal  @db.Decimal(14, 2)
  metodo     String   @default("TRANSFERENCIA")
  referencia String?
  fecha      DateTime @default(now())
  createdAt  DateTime @default(now())

  @@map("pagos_factura")
  @@index([facturaId])
}

// ── Tareas y seguimientos (submódulo CRM) ──
model Tarea {
  id           String    @id @default(cuid())
  titulo       String
  descripcion  String?   @db.Text
  tipo         String    @default("SEGUIMIENTO") // SEGUIMIENTO, LLAMADA, EMAIL, REUNION, COTIZACION, VISITA
  prioridad    String    @default("NORMAL")      // BAJA, NORMAL, ALTA, URGENTE
  estado       String    @default("PENDIENTE")   // PENDIENTE, EN_PROGRESO, COMPLETADA, CANCELADA
  fechaVence   DateTime?
  completadaEn DateTime?
  clienteId    String?
  cliente      Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  asignadoId   String?
  asignado     Usuario?  @relation(fields: [asignadoId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("tareas")
  @@index([estado])
  @@index([asignadoId])
  @@index([clienteId])
  @@index([fechaVence])
}

// ── Proveedores y compras (submódulo ERP) ──
model Proveedor {
  id           String   @id @default(cuid())
  nombre       String
  contacto     String?
  email        String?
  telefono     String?
  nit          String?
  direccion    String?
  ciudad       String?
  categorias   String[] @default([])
  notas        String?  @db.Text
  leadTimeDias Int?     // tiempo de entrega estimado
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ordenes      OrdenCompra[]

  @@map("proveedores")
  @@index([activo])
}

model OrdenCompra {
  id           String   @id @default(cuid())
  numero       String   @unique
  proveedorId  String
  proveedor    Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  estado       String   @default("BORRADOR") // BORRADOR, ENVIADA, RECIBIDA_PARCIAL, RECIBIDA, CANCELADA
  total        Decimal  @default(0) @db.Decimal(14, 2)
  notas        String?  @db.Text
  items        Json     @default("[]")
  fechaEsperada DateTime?
  recibidaEn   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("ordenes_compra")
  @@index([proveedorId])
  @@index([estado])
}

// ── Plantillas y automatización (submódulo Nexus) ──
model PlantillaNexus {
  id          String   @id @default(cuid())
  nombre      String
  categoria   String   @default("GENERAL") // GENERAL, SALUDO, COTIZACION, SEGUIMIENTO, DESPEDIDA, FAQ
  canal       String   @default("todos")   // todos, whatsapp, email, instagram...
  contenido   String   @db.Text
  atajo       String?  // ej: /saludo
  activo      Boolean  @default(true)
  vecesUsada  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("plantillas_nexus")
  @@index([categoria])
  @@index([activo])
}

model Cotizacion {
  id               String   @id @default(cuid())
  numero           String   @unique
  clienteId        String
  cliente          Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  vendedorId       String?
  vendedor         Usuario? @relation(fields: [vendedorId], references: [id], onDelete: SetNull)
  estado           String   @default("BORRADOR")
  subtotal         Decimal  @db.Decimal(14,2) @default(0)
  descuento        Decimal  @db.Decimal(14,2) @default(0)
  iva              Decimal  @db.Decimal(14,2) @default(0)
  total            Decimal  @db.Decimal(14,2) @default(0)
  validezDias      Int      @default(30)
  notas            String?  @db.Text
  tieneInstalacion Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items   ItemCotizacion[]
  pedidos Pedido[]

  @@map("cotizaciones")
  @@index([clienteId])
  @@index([vendedorId])
  @@index([estado])
}

model ItemCotizacion {
  id             String     @id @default(cuid())
  cotizacionId   String
  cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  productoId     String?
  descripcion    String
  cantidad       Decimal    @db.Decimal(10,2)
  precioUnitario Decimal    @db.Decimal(14,2)
  descuento      Decimal    @db.Decimal(5,2) @default(0)
  subtotal       Decimal    @db.Decimal(14,2)
  unidad         String?
  orden          Int        @default(0)

  @@map("items_cotizacion")
  @@index([cotizacionId])
}

model Pedido {
  id               String     @id @default(cuid())
  numero           String     @unique
  cotizacionId     String?
  cotizacion       Cotizacion? @relation(fields: [cotizacionId], references: [id], onDelete: SetNull)
  clienteId        String
  cliente          Cliente    @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  vendedorId       String?
  vendedor         Usuario?   @relation(fields: [vendedorId], references: [id], onDelete: SetNull)
  estado           String     @default("NUEVO")
  tieneInstalacion Boolean    @default(false)
  fechaEntrega     DateTime?
  direccionEntrega String?
  notas            String?    @db.Text
  total            Decimal    @db.Decimal(14,2) @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  items        ItemPedido[]
  instalacion  Instalacion?

  @@map("pedidos")
  @@index([clienteId])
  @@index([vendedorId])
  @@index([estado])
}

model ItemPedido {
  id             String  @id @default(cuid())
  pedidoId       String
  pedido         Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  productoId     String?
  descripcion    String
  cantidad       Decimal @db.Decimal(10,2)
  precioUnitario Decimal @db.Decimal(14,2)
  subtotal       Decimal @db.Decimal(14,2)
  unidad         String?
  orden          Int     @default(0)

  @@map("items_pedido")
  @@index([pedidoId])
}

model Instalacion {
  id             String    @id @default(cuid())
  pedidoId       String    @unique
  pedido         Pedido    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  tecnicoId      String?
  tecnico        Usuario?  @relation(fields: [tecnicoId], references: [id], onDelete: SetNull)
  estado         String    @default("PENDIENTE")
  fechaAgendada  DateTime?
  fechaRealizada DateTime?
  direccion      String?
  ciudad         String?
  notas          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("instalaciones")
  @@index([estado])
  @@index([tecnicoId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  usuarioId String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@map("refresh_tokens")
  @@index([token])
  @@index([usuarioId])
}

// ─────────────────────────────────────────────
// PRODUCTOS
// ─────────────────────────────────────────────

model Producto {
  id          String         @id @default(cuid())
  wcId        Int?           @unique
  tipo        TipoProducto   @default(SIMPLE)
  sku         String         @unique
  nombre      String
  slug        String         @unique
  publicado   Boolean        @default(false)
  visibilidad String         @default("visible")
  destacado   Boolean        @default(false)

  descCorta   String?        @db.Text
  descripcion String?        @db.Text

  // SEO (autogenerado con IA)
  seoTitulo      String?
  seoDescripcion String?     @db.Text
  seoKeywords    String[]    @default([])
  seoTexto       String?     @db.Text

  precioNormal  Decimal?     @db.Decimal(14, 2)
  precioOferta  Decimal?     @db.Decimal(14, 2)

  estadoImpuesto  String?
  claseImpuesto   String?

  enStock           Boolean  @default(true)
  stock             Int      @default(0)
  stockMinimo       Int      @default(15)
  permiteBackorders String   @default("no")

  pesoKg  Decimal?           @db.Decimal(8, 3)
  largoCm Decimal?           @db.Decimal(8, 2)
  anchoCm Decimal?           @db.Decimal(8, 2)
  altoCm  Decimal?           @db.Decimal(8, 2)

  categorias  String[]
  etiquetas   String[]
  claseEnvio  String?
  notaCompra  String?        @db.Text
  permiteResenas Boolean     @default(true)

  // Campos ACF Generales
  acfSkuInterno        String?
  acfMarcaFabricante   String?
  acfUnidadVenta       String?
  acfFabricacionMedida Boolean  @default(false)
  acfInstalacion       Boolean  @default(false)
  acfGarantiaAnos      Int?
  acfAplicaciones      String[]
  acfColores           String[]
  acfNormas            String[]
  acfFichaTecnicaPdf   String?
  acfCertificaciones   String[]
  acfExtra             Json     @default("{}")

  // Control interno
  intEstado          EstadoProducto @default(BORRADOR)
  intResponsable     String?
  intObservaciones   String?        @db.Text
  intListoExportar   Boolean        @default(false)
  intExportadoEn     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  imagenes AcfImagen[]
  errores  ErrorValidacion[]

  acfMM AcfMallasMetalicas?
  acfBH AcfBalcones?
  acfNY AcfNylon?
  acfPL AcfPlasticas?
  acfSP AcfSeguridadPerimetral?

  @@map("productos")
  @@index([sku])
  @@index([intEstado])
  @@index([publicado])
  @@index([categorias])
}

enum TipoProducto {
  SIMPLE
  VARIABLE
  AGRUPADO
  EXTERNO
}

enum EstadoProducto {
  BORRADOR
  REVISION
  LISTO
  PUBLICADO
  ARCHIVADO
}

// ─────────────────────────────────────────────
// IMÁGENES
// ─────────────────────────────────────────────

model AcfImagen {
  id          String   @id @default(cuid())
  productoId  String
  producto    Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  posicion    Int      @default(0)
  urlImagen   String
  altText     String?
  titulo      String?
  esPrincipal Boolean  @default(false)
  urlValida   Boolean?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("imagenes")
  @@index([productoId])
}

// ─────────────────────────────────────────────
// ACF POR CATEGORÍA
// ─────────────────────────────────────────────

model AcfMallasMetalicas {
  id         String   @id @default(cuid())
  productoId String   @unique
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  calibre          String?
  aperturaLuz      String?
  tipoAcero        String?
  tipoBano         String?
  rolloAncho       Decimal? @db.Decimal(8, 2)
  rolloLargo       Decimal? @db.Decimal(8, 2)
  acabado          String?
  normaFabricacion String?

  @@map("acf_mallas_metalicas")
}

model AcfBalcones {
  id         String   @id @default(cuid())
  productoId String   @unique
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  materialMarco      String?
  acabadoMarco       String?
  tipoApertura       String?
  resistenciaViento  String?
  claseTermica       String?

  @@map("acf_balcones")
}

model AcfNylon {
  id         String   @id @default(cuid())
  productoId String   @unique
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  denier        String?
  trama         String?
  resistenciaUV String?
  cargaRuptura  String?

  @@map("acf_nylon")
}

model AcfPlasticas {
  id         String   @id @default(cuid())
  productoId String   @unique
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  material           String?
  densidad           String?
  porcentajeSombra   String?
  temperaturaMax     String?

  @@map("acf_plasticas")
}

model AcfSeguridadPerimetral {
  id         String   @id @default(cuid())
  productoId String   @unique
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  claseSeguridadEn     String?
  alturaMinimaRecom    String?
  sistemaAnclaje       String?
  resistenciaTraccion  String?
  certificacionIEC     String?

  @@map("acf_seguridad_perimetral")
}

// ─────────────────────────────────────────────
// ERRORES DE VALIDACIÓN
// ─────────────────────────────────────────────

model ErrorValidacion {
  id         String   @id @default(cuid())
  productoId String?
  producto   Producto? @relation(fields: [productoId], references: [id], onDelete: SetNull)

  skuRef            String?
  hoja              String?
  columna           String?
  valorActual       String?
  tipoError         String
  severidad         SeveridadError
  mensaje           String           @db.Text
  accionRecomendada String?          @db.Text
  estadoCorreccion  EstadoCorreccion @default(PENDIENTE)

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@map("errores_validacion")
  @@index([productoId])
  @@index([severidad])
  @@index([estadoCorreccion])
}

enum SeveridadError {
  CRITICO
  ALTO
  MEDIO
  BAJO
  INFO
}

enum EstadoCorreccion {
  PENDIENTE
  EN_PROCESO
  RESUELTO
  IGNORADO
}

// ─────────────────────────────────────────────
// LOGS DE AUDITORÍA
// ─────────────────────────────────────────────

model Log {
  id         String   @id @default(cuid())
  usuarioId  String?
  usuario    Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  accion          String
  detalle         String?  @db.Text
  resultado       String?
  archivoGenerado String?
  totalFilas      Int?
  ipAddress       String?
  userAgent       String?
  metadata        Json?

  createdAt DateTime @default(now())

  @@map("logs")
  @@index([usuarioId])
  @@index([accion])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// CATÁLOGOS
// ─────────────────────────────────────────────

model Catalogo {
  id     String       @id @default(cuid())
  tipo   TipoCatalogo
  valor  String
  label  String
  orden  Int          @default(0)
  activo Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tipo, valor])
  @@map("catalogos")
  @@index([tipo])
}

enum TipoCatalogo {
  CATEGORIA
  MARCA
  CLASE_ENVIO
  CLASE_IMPUESTO
  UNIDAD_VENTA
  COLOR
  NORMA
  APLICACION
}

// ─────────────────────────────────────────────
// CONFIGURACIÓN (valores cifrados en DB)
// ─────────────────────────────────────────────

model Configuracion {
  id        String  @id @default(cuid())
  clave     String  @unique
  valor     String  @db.Text   // cifrado con AES-256-GCM si encrypted=true
  encrypted Boolean @default(false)
  descripcion String?

  updatedAt DateTime @updatedAt

  @@map("configuracion")
}

// ─────────────────────────────────────────────
// WOOCOMMERCE SYNC
// ─────────────────────────────────────────────

model WooCommerceSync {
  id             String   @id @default(cuid())
  tipo           String   // 'export' | 'import' | 'sync'
  estado         String   // 'pendiente' | 'procesando' | 'completado' | 'error'
  totalProductos Int      @default(0)
  procesados     Int      @default(0)
  errores        Int      @default(0)
  detalle        Json?
  archivoCSV     String?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@map("woocommerce_sync")
  @@index([estado])
  @@index([startedAt])
}

// ─────────────────────────────────────────────
// NOTIFICACIONES
// ─────────────────────────────────────────────

model Notificacion {
  id      String           @id @default(cuid())
  tipo    TipoNotificacion
  titulo  String
  mensaje String           @db.Text
  leida   Boolean          @default(false)
  data    Json?

  createdAt DateTime  @default(now())
  leidaAt   DateTime?

  @@map("notificaciones")
  @@index([leida])
  @@index([createdAt])
}

enum TipoNotificacion {
  STOCK_CRITICO
  STOCK_BAJO
  ERROR_VALIDACION
  EXPORTACION_COMPLETA
  SYNC_WOOCOMMERCE
  SISTEMA
  NEXUS_MENSAJE
}

// ─────────────────────────────────────────────
// NEXUS — HUB OMNICANAL
// ─────────────────────────────────────────────

model NexusConexion {
  id          String   @id @default(cuid())
  canal       String
  nombre      String
  descripcion String?
  config      Json     @default("{}")
  activo      Boolean  @default(true)
  webhookUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversaciones NexusConversacion[]

  @@map("nexus_conexiones")
  @@index([canal])
  @@index([activo])
}

model NexusConversacion {
  id          String        @id @default(cuid())
  conexionId  String
  conexion    NexusConexion @relation(fields: [conexionId], references: [id], onDelete: Cascade)
  canal       String
  remitente   String
  emailRemit  String?
  telRemit    String?
  asunto      String?
  estado      String        @default("ABIERTA")
  prioridad   String        @default("NORMAL")
  leida       Boolean       @default(false)
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  mensajes NexusMensaje[]

  @@map("nexus_conversaciones")
  @@index([conexionId])
  @@index([estado])
  @@index([leida])
  @@index([createdAt])
}

model NexusMensaje {
  id              String            @id @default(cuid())
  conversacionId  String
  conversacion    NexusConversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  agenteId        String?
  agente          Usuario?          @relation(fields: [agenteId], references: [id], onDelete: SetNull)
  origen          String
  contenido       String            @db.Text
  tipo            String            @default("texto")
  metadata        Json?
  leido           Boolean           @default(false)
  createdAt       DateTime          @default(now())

  @@map("nexus_mensajes")
  @@index([conversacionId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// REPORTES DE ERROR (enviados por usuarios)
// ─────────────────────────────────────────────

model ReporteError {
  id            String   @id @default(cuid())
  usuarioId     String?
  usuarioNombre String
  usuarioRol    String
  modulo        String              // ruta/ubicación (pathname)
  accion        String?             // qué estaba haciendo
  descripcion   String?  @db.Text
  url           String?
  userAgent     String?
  estado        String   @default("NUEVO") // NUEVO, EN_REVISION, RESUELTO
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("reportes_error")
  @@index([estado])
